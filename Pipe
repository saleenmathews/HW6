#region imports
import math
import numpy as np
import random as rnd
from scipy.optimize import fsolve
from Fluid import Fluid
#endregion

#region class definitions
class Pipe:
    # region constructor
    def __init__(self, Start='A', End='B', L=100, D=200, r=0.00025, fluid=Fluid()):
        """
        Defines a generic pipe with orientation from lowest letter to highest alphabetically.
        :param Start: start node (string)
        :param End: end node (string)
        :param L: pipe length in meters
        :param D: pipe diameter in mm
        :param r: pipe roughness in meters
        :param fluid: Fluid object
        """
        # region attributes
        self.startNode = min(Start, End)
        self.endNode = max(Start, End)
        self.length = L
        self.r = r
        self.fluid = fluid

        self.d = D / 1000.0               # diameter in meters
        self.relrough = self.r / self.d   # relative roughness
        self.A = math.pi / 4.0 * self.d**2 # cross-sectional area in m^2
        self.Q = 10                        # initial flow in L/s
        self.vel = self.V()                # average velocity in m/s
        self.reynolds = self.Re()          # Reynolds number
        # endregion

    # region methods
    def V(self):
        """Calculate average velocity in the pipe (m/s)."""
        # Q in L/s -> convert to m^3/s
        self.vel = (self.Q / 1000.0) / self.A
        return self.vel

    def Re(self):
        """Calculate Reynolds number."""
        # Re = rho * V * D / mu
        self.vel = self.V()  # ensure velocity is updated
        self.reynolds = (self.fluid.rho * self.vel * self.d) / self.fluid.mu
        return self.reynolds

    def FrictionFactor(self):
        """Darcy friction factor for laminar, turbulent, transitional flow."""
        Re = self.Re()
        rr = self.relrough

        # Turbulent: Colebrook-White
        def CB():
            cb = lambda f: 1 / (f**0.5) + 2.0 * np.log10(rr / 3.7 + 2.51 / (Re * f**0.5))
            result = fsolve(cb, 0.01)
            return result[0]

        # Laminar
        def lam():
            return 64 / Re

        if Re >= 4000:
            return CB()
        elif Re <= 2000:
            return lam()
        else:
            # transitional
            mean = lam() + ((Re - 2000) / 2000) * (CB() - lam())
            sig = 0.2 * mean
            return rnd.normalvariate(mean, sig)

    def frictionHeadLoss(self):
        """Calculate head loss in meters using Darcy-Weisbach."""
        g = 9.81
        ff = self.FrictionFactor()
        V = self.V()
        hl = ff * (self.length / self.d) * (V**2) / (2 * g)
        return hl

    def getFlowHeadLoss(self, s):
        """Head loss along the pipe depending on traversal direction."""
        nTraverse = 1 if s == self.startNode else -1
        nFlow = 1 if self.Q >= 0 else -1
        return nTraverse * nFlow * self.frictionHeadLoss()

    def Name(self):
        """Return the pipe name."""
        return f"{self.startNode}-{self.endNode}"

    def oContainsNode(self, node):
        """Check if pipe connects to a node."""
        return self.startNode == node or self.endNode == node

    def printPipeFlowRate(self):
        print(f"The flow in segment {self.Name()} is {self.Q:.2f} L/s")

    def getFlowIntoNode(self, n):
        """Flow into a given node."""
        if n == self.startNode:
            return -self.Q
        return self.Q
    # endregion
#endregion
